@page
@model PatientPortalApp.Pages.ReportModel
@{
    Layout = null;
    ViewData["Title"] = "Patient Report";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            color: #2c3e50;
            padding-top: 30px;
        }

        header {
            background-color: #2ecc71;
            color: white;
            padding: 18px 30px;
            display: flex;
            align-items: center;
            box-shadow: 0 2px 6px rgba(0,0,0,0.12);
        }

        header img {
            height: 44px;
            width: auto;
            margin-right: 15px;
        }

        header h1 {
            margin: 0;
            font-size: 1.55rem;
        }

        .report-container {
            max-width: 900px;
            margin: 34px auto;
            padding: 34px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 26px rgba(0, 0, 0, 0.08);
        }

        .meta {
            margin-bottom: 10px;
            font-size: 1.02rem;
        }

        .section {
            margin-top: 22px;
            padding: 18px 20px;
            border-radius: 12px;
            background: #f9fbfc;
            border-left: 6px solid #ccc;
        }

        .diagnosis {
            background: #ecf6fc;
            border-left-color: #3498db;
        }

        .medication {
            background: #e8f8f5;
            border-left-color: #27ae60;
        }

        .notes {
            background: #f4ecf7;
            border-left-color: #8e44ad;
        }

        .section h3 {
            margin: 0 0 10px 0;
            font-size: 1.22rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section p {
            margin: 0;
            font-size: 1.08rem;
            line-height: 1.7;
        }

        .back-button {
            display: inline-block;
            margin-top: 28px;
            padding: 11px 18px;
            background: #3498db;
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            transition: background 0.2s ease;
        }

        .back-button:hover {
            background: #2980b9;
        }
    </style>
</head>
<body>
    <header>
        <img src="/images/logo.png" alt="BRIOTA Logo" />
        <h1>BRIOTA Patient Portal</h1>
    </header>

    <div class="report-container">
        <h2>Patient Report</h2>
        <p class="meta"><strong>Patient:</strong> @Model.PatientName</p>
        <p class="meta"><strong>Date of Entry:</strong> @Model.DateOfEntry.ToString("yyyy-MM-dd")</p>

        <div class="section diagnosis">
            <h3><i class="fas fa-stethoscope"></i> Diagnosis</h3>
            <p>@Model.Diagnosis</p>
        </div>

        <div class="section medication">
            <h3><i class="fas fa-pills"></i> Medication</h3>
            <p>@Model.Medication</p>
        </div>

        <div class="section notes">
            <h3><i class="fas fa-notes-medical"></i> Notes</h3>
            <p>@Model.Notes</p>
        </div>

        <a href="/Dashboard" class="back-button">← Back to Dashboard</a>
    </div>
</body>
</html>