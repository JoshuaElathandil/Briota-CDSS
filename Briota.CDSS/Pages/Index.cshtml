@page
@model Briota.CDSS.Pages.IndexModel
@{
    ViewData["Title"] = "Clinical Dashboard";
}

<div class="container-fluid px-4 py-3">
    <div class="row align-items-center mb-4">
        <div class="col-auto">
            <div class="bg-primary text-white p-3 rounded-3 shadow-sm">
                <i class="bi bi-speedometer2 fs-2"></i>
            </div>
        </div>
        <div class="col">
            <h1 class="h3 mb-0 fw-bold">Clinical Command Center</h1>
            <p class="text-muted mb-0">Welcome back, <strong>@User.Identity?.Name</strong>. You are logged in as a <strong>@(User.IsInRole("Admin") ? "System Admin" : "Clinical Provider")</strong>.</p>
        </div>
    </div>

    <!-- Quick Stats (Simulated) -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Active Patients</h6>
                            <h2 class="fw-bold mb-0">1,284</h2>
                        </div>
                        <div class="text-success"><i class="bi bi-graph-up fs-3"></i></div>
                    </div>
                    <div class="mt-3 small text-success">
                        <i class="bi bi-arrow-up-right me-1"></i> 12% increase this month
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Assessments</h6>
                            <h2 class="fw-bold mb-0">452</h2>
                        </div>
                        <div class="text-info"><i class="bi bi-clipboard2-check fs-3"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        Pending review: <span class="badge bg-warning text-dark">24</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">Avg. Health Score</h6>
                            <h2 class="fw-bold mb-0">72.4</h2>
                        </div>
                        <div class="text-primary"><i class="bi bi-heart-pulse fs-3"></i></div>
                    </div>
                    <div class="mt-3 small text-muted">
                        Across all centers
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h6 class="text-muted text-uppercase small fw-bold">SQL Opt. Win</h6>
                            <h2 class="fw-bold mb-0">37x</h2>
                        </div>
                        <div class="text-warning"><i class="bi bi-lightning-charge-fill fs-3"></i></div>
                    </div>
                    <div class="mt-3 small text-warning">
                        Latency: 12ms (Optimized)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Role-Based Navigation Grid -->
    <h5 class="fw-bold mb-3">Clinical Modules</h5>
    <div class="row g-4">
        <!-- Patient Directory (Available to all Clinical Roles) -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm card-hover h-100">
                <div class="card-body text-center p-4">
                    <div class="icon-circle bg-primary-soft text-primary mb-3 mx-auto">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Patient Directory</h5>
                    <p class="card-text text-muted small">Manage clinical records, view CDSS results, and update patient metadata.</p>
                    <a asp-page="/Patients/Index" class="btn btn-outline-primary w-100 rounded-pill">Enter Directory</a>
                </div>
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.Identity?.IsAuthenticated != true)
        {
            <!-- Clinical Analytics -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm card-hover h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-success-soft text-success mb-3 mx-auto">
                            <i class="bi bi-activity fs-3"></i>
                        </div>
                        <h5 class="card-title fw-bold">Concurrency Lab</h5>
                        <p class="card-text text-muted small">Demonstrate optimistic concurrency handling using the Patient Edit workflow.</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Patients/Index" class="btn btn-outline-success w-100 rounded-pill">Open Laboratory</a>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted w-100 p-2">Login Required</span>
                        }
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Admin"))
        {
            <!-- Admin Management -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm card-hover h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-danger-soft text-danger mb-3 mx-auto">
                            <i class="bi bi-shield-lock fs-3"></i>
                        </div>
                        <h5 class="card-title fw-bold">Admin Console</h5>
                        <p class="card-text text-muted small">Configure clinical centers, map roles, and audit system performance logs.</p>
                        <a asp-page="/Admin/Index" class="btn btn-outline-danger w-100 rounded-pill">Manage System</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-primary-soft { background-color: rgba(13, 110, 253, 0.1); }
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
    
    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .card-hover:hover {
        transform: translateY(-5px);
        transition: transform 0.2s ease-in-out;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>
