@page
@model Briota.CDSS.Pages.Patients.EditModel
@{
    ViewData["Title"] = "Concurrency Laboratory - Edit Patient";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Patients</a></li>
            <li class="breadcrumb-item active">Edit</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                    <div class="bg-success-soft p-2 rounded me-3">
                        <i class="bi bi-activity text-success fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">Concurrency Laboratory</h4>
                        <p class="text-muted small mb-0">Demostrating Optimistic Concurrency Control</p>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>
                        <input type="hidden" asp-for="Patient.Id" />
                        <input type="hidden" asp-for="Patient.ConcurrencyStamp" />
                        <input type="hidden" asp-for="Patient.AreYouSmoker" />
                        <input type="hidden" asp-for="Patient.DateOfBirth" />
                        <input type="hidden" asp-for="Patient.Gender" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">First Name</label>
                                <input asp-for="Patient.FirstName" class="form-control" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Last Name</label>
                                <input asp-for="Patient.LastName" class="form-control" readonly />
                            </div>

                            <div class="col-12 mt-4">
                                <div class="p-3 bg-light rounded-3 border">
                                    <label asp-for="Patient.Symptoms" class="form-label fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Symptoms</label>
                                    <textarea asp-for="Patient.Symptoms" class="form-control border-0 bg-white" rows="4" placeholder="Update symptoms for concurrency test..."></textarea>
                                    <span asp-validation-for="Patient.Symptoms" class="text-danger small mt-1 d-block"></span>
                                    
                                    @if (Model.DbSymptoms != null)
                                    {
                                        <div class="mt-3 p-2 bg-warning-soft border border-warning rounded">
                                            <i class="bi bi-info-circle-fill text-warning me-2"></i>
                                            <strong>Database Version:</strong> "@Model.DbSymptoms"
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-5">
                            <button type="submit" class="btn btn-success px-4 rounded-pill">
                                <i class="bi bi-save me-2"></i>Save Changes
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Instructions for Concurrency Test -->
            <div class="card border-info mt-4">
                <div class="card-body">
                    <h6 class="text-info fw-bold"><i class="bi bi-magic me-2"></i>How to test Concurrency:</h6>
                    <ol class="small mb-0 mt-2 text-muted">
                        <li>Open this same patient edit page in **two separate Chrome tabs**.</li>
                        <li>In **Tab 1**, change symptoms to "Tab 1 Fix" and click **Save**. (Success)</li>
                        <li>Switch to **Tab 2**, change symptoms to "Tab 2 Conflict" and click **Save**.</li>
                        <li>**Observe**: The system will detect that the record changed in the background and show the conflict warning!</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-warning-soft { background-color: rgba(255, 193, 7, 0.1); }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
