@page
@model Briota.CDSS.Pages.Patients.IndexModel
@{
    ViewData["Title"] = "Patient Directory";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h1 class="h3 text-primary"><i class="bi bi-people-fill"></i> Patient Directory</h1>
        <div class="badge bg-info text-dark p-2">
            @(string.IsNullOrEmpty(Model.SearchString) ? $"Records Found: {Model.TotalCount}" : $"Found {Model.TotalCount} results for '{Model.SearchString}'")
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" class="d-flex gap-2">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="SearchString" value="@Model.SearchString" class="form-control border-start-0" placeholder="Search by name, ID or phone..." />
                    <button class="btn btn-primary" type="submit">Search</button>
                </div>
                @if (!string.IsNullOrEmpty(Model.SearchString))
                {
                    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <table id="patientsTable" class="table table-hover align-middle border-light" style="width:100%">
                <thead class="bg-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Patients) {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <strong>@item.FirstName @item.LastName</strong>
                            <div class="small text-muted">@item.UniqueId</div>
                        </td>
                        <td>@item.Email</td>
                        <td>@item.ContactNumber</td>
                        <td>@item.CreatedDate?.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-primary shadow-sm" asp-page="./Details" asp-route-id="@item.Id">
                                    <i class="bi bi-file-medical"></i> View CDSS
                                </a>
                                <a class="btn btn-sm btn-outline-success shadow-sm" asp-page="./Edit" asp-route-id="@item.Id">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>

            <!-- Pagination -->
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.PageIndex <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-SearchString="@Model.SearchString">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>
                    
                    <li class="page-item disabled">
                        <span class="page-link text-dark bg-light px-4">
                            Page <strong>@Model.PageIndex</strong> of <strong>@Model.TotalPages</strong>
                        </span>
                    </li>

                    <li class="page-item @(Model.PageIndex >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-SearchString="@Model.SearchString">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
                <div class="text-center text-muted small mt-2">
                    Showing @Model.Patients.Count of @Model.TotalCount total records
                </div>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Disable built-in DataTables paging since we use server-side pagination
            $('#patientsTable').DataTable({
                "paging": false,
                "info": false,
                "searching": false, 
                "order": [[4, "desc"]] 
            });
        });
    </script>
}
