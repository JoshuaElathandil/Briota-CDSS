@page
@model Briota.CDSS.Pages.Admin.TechnicalShowroomModel
@{
    ViewData["Title"] = "Technical Comparison Showroom";
}

<div class="container-fluid px-4 py-3">
    <div class="row align-items-center mb-4">
        <div class="col-auto">
            <div class="bg-dark text-white p-3 rounded-3 shadow-sm">
                <i class="bi bi-intersect fs-2"></i>
            </div>
        </div>
        <div class="col">
            <h1 class="h3 mb-0 fw-bold">Clinical Comparison Showroom</h1>
            <p class="text-muted mb-0">Interactive side-by-side demonstration of system evolution.</p>
        </div>
        <div class="col-auto">
            <a asp-page="/Admin/Index" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i> Back to Console
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SearchResult) || !string.IsNullOrEmpty(Model.ConcurrencyResult) || !string.IsNullOrEmpty(Model.SafetyResult))
    {
        <div class="alert alert-dark border-0 shadow-sm rounded-3 mb-4 animate__animated animate__fadeIn">
            <div class="d-flex align-items-center">
                <div class="me-3">
                    <i class="bi bi-cpu-fill fs-3 text-warning"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-1">Execution Metrics</h6>
                    @if (!string.IsNullOrEmpty(Model.SearchResult))
                    {
                        <p class="mb-0 small"><strong>Result:</strong> @Model.SearchResult | <strong>Latency:</strong> <span class="@(Model.SearchLatency > 2000 ? "text-danger fw-bold" : "text-success fw-bold")">@Model.SearchLatency ms</span></p>
                    }
                    @if (!string.IsNullOrEmpty(Model.ConcurrencyResult))
                    {
                        <p class="mb-0 small"><strong>Transaction Status:</strong> @Model.ConcurrencyResult</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.SafetyResult))
                    {
                        <p class="mb-0 small"><strong>System State:</strong> @Model.SafetyResult</p>
                    }
                </div>
            </div>
        </div>
    }

    <div class="row g-4">
        <!-- TIER 0: BASELINE PROTOTYPE -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 bg-light-danger border-start border-danger border-5">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="badge bg-danger p-2 me-3"><i class="bi bi-0-circle-fill fs-4"></i></div>
                        <div>
                            <h4 class="fw-bold mb-0 text-danger">Tier 0: Baseline Prototype</h4>
                            <p class="text-muted small mb-0">Implicit Trust | Unoptimized | Fragile</p>
                        </div>
                    </div>

                    <form method="post">
                        <!-- Search Interaction -->
                        <div class="mb-4 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-search me-2"></i>Unindexed Interaction</h6>
                            <p class="small text-muted">Triggers a full-table scan with artificial 'Junior' latency simulation.</p>
                            <div class="input-group mb-2">
                                <input type="text" name="query" class="form-control form-control-sm" placeholder="Search Patient..." value="ketki">
                                <button asp-page-handler="RunSlowSearch" class="btn btn-danger btn-sm">Start Fragmented Search</button>
                            </div>
                        </div>

                        <!-- Concurrency Interaction -->
                        <div class="mb-4 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-arrow-repeat me-2"></i>Silent Data Loss (Race)</h6>
                            <p class="small text-muted">Updates data without version verification. Overwrites previous changes silently.</p>
                            <button asp-page-handler="SimulateOverwrite" class="btn btn-outline-danger btn-sm w-100">Simulate Silent Overwrite</button>
                        </div>

                        <!-- Safety Interaction -->
                        <div class="mb-0 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-exclamation-octagon me-2"></i>Resource Failure (Crash)</h6>
                            <p class="small text-muted">Trigger an implicit null access to witness a standard System 500 crash.</p>
                            <button asp-page-handler="SimulateCrash" class="btn btn-danger btn-sm w-100">Trigger System Crash</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- TIER 1: PRODUCTION HARDENED -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 bg-light-success border-start border-success border-5">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="badge bg-success p-2 me-3"><i class="bi bi-1-circle-fill fs-4"></i></div>
                        <div>
                            <h4 class="fw-bold mb-0 text-success">Tier 1: Production Hardened</h4>
                            <p class="text-muted small mb-0">Defensive | Optimized | Enterprise Ready</p>
                        </div>
                    </div>

                    <form method="post">
                        <!-- Search Interaction -->
                        <div class="mb-4 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Indexed Execution</h6>
                            <p class="small text-muted">Leverages SQL Non-Clustered indexes and SARGable StartsWith query.</p>
                            <div class="input-group mb-2">
                                <input type="text" name="query" class="form-control form-control-sm" placeholder="Search Patient..." value="ketki">
                                <button asp-page-handler="RunFastSearch" class="btn btn-success btn-sm">Execute Optimized Search</button>
                            </div>
                        </div>

                        <!-- Concurrency Interaction -->
                        <div class="mb-4 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-shield-check me-2 text-primary"></i>Conflict Shield (OCC)</h6>
                            <p class="small text-muted">Uses Optimistic Concurrency Control to block overwrites and protect data.</p>
                            <button asp-page-handler="SimulateConflict" class="btn btn-outline-success btn-sm w-100">Simulate Concurrency Shield</button>
                        </div>

                        <!-- Safety Interaction -->
                        <div class="mb-0 p-3 bg-white rounded-3 shadow-xs border">
                            <h6 class="fw-bold"><i class="bi bi-check-all me-2 text-success"></i>Graceful Resilience</h6>
                            <p class="small text-muted">Uses null-coalescing and safe-access patterns to prevent crashes.</p>
                            <button asp-page-handler="SimulateSafe" class="btn btn-success btn-sm w-100">Show Resilient Fallback</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light-danger { background-color: rgba(220, 53, 69, 0.05); }
    .bg-light-success { background-color: rgba(25, 135, 84, 0.05); }
    .shadow-xs { box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.02) !important; }
</style>
